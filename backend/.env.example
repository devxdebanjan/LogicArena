# =============================================================================
# LogicArena Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://logicarena:logicarena@localhost:5432/logicarena

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# IMPORTANT: Generate a strong secret for production!
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-secrets-token-urlsafe-64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
GUEST_CLEANUP_DAYS=45

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_NAME=LogicArena
LOG_LEVEL=DEBUG
